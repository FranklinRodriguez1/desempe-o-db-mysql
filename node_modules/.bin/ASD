// Obtener todos los usuarios - READ
app.get('/api/usuarios', (req, res) => {
  // codigo de ia - ruta GET usuarios
  connection.query('SELECT * FROM usuarios', (err, results) => {
    // codigo de ia - consulta todos
    if (err) return res.status(500).json({ error: err.message }); // codigo de ia - maneja error
    res.json(results); // codigo de ia - retorna resultados
  });
});

// Obtener un usuario por ID - READ
app.get('/api/usuarios/:id', (req, res) => {
  // codigo de ia - ruta GET usuario por ID
  const { id } = req.params; // codigo de ia - obtiene ID de params
  connection.query(
    'SELECT * FROM usuarios WHERE id = ?',
    [id],
    (err, results) => {
      // codigo de ia - consulta por ID
      if (err) return res.status(500).json({ error: err.message }); // codigo de ia - maneja error
      if (results.length === 0)
        return res.status(404).json({ error: 'Usuario no encontrado' }); // codigo de ia - no encontrado
      res.json(results[0]); // codigo de ia - retorna usuario
    }
  );
});

// Crear usuario - CREATE
app.post('/api/usuarios', (req, res) => {
  // codigo de ia - ruta POST crear usuario
  const { nombre, email, password, rol } = req.body; // codigo de ia - obtiene datos

  if (!nombre || !email || !password) {
    // codigo de ia - valida campos requeridos
    return res
      .status(400)
      .json({ error: 'Nombre, email y password son requeridos' }); // codigo de ia - error
  }

  const query =
    'INSERT INTO usuarios (nombre, email, password, rol) VALUES (?, ?, ?, ?)'; // codigo de ia - SQL insert
  connection.query(
    query,
    [nombre, email, password, rol || 'empleado'],
    (err, result) => {
      // codigo de ia - ejecuta
      if (err) return res.status(500).json({ error: err.message }); // codigo de ia - maneja error
      res.status(201).json({ message: 'Usuario creado', id: result.insertId }); // codigo de ia - éxito
    }
  );
});

// Actualizar usuario - UPDATE
app.put('/api/usuarios/:id', (req, res) => {
  // codigo de ia - ruta PUT actualizar usuario
  const { id } = req.params; // codigo de ia - obtiene ID
  const { nombre, email, password, rol } = req.body; // codigo de ia - obtiene datos

  const query =
    'UPDATE usuarios SET nombre = ?, email = ?, password = ?, rol = ? WHERE id = ?'; // codigo de ia - SQL update
  connection.query(query, [nombre, email, password, rol, id], (err, result) => {
    // codigo de ia - ejecuta
    if (err) return res.status(500).json({ error: err.message }); // codigo de ia - maneja error
    if (result.affectedRows === 0)
      return res.status(404).json({ error: 'Usuario no encontrado' }); // codigo de ia - no encontrado
    res.json({ message: 'Usuario actualizado' }); // codigo de ia - éxito
  });
});

// Eliminar usuario - DELETE
app.delete('/api/usuarios/:id', (req, res) => {
  // codigo de ia - ruta DELETE usuario
  const { id } = req.params; // codigo de ia - obtiene ID
  connection.query('DELETE FROM usuarios WHERE id = ?', [id], (err, result) => {
    // codigo de ia - elimina
    if (err) return res.status(500).json({ error: err.message }); // codigo de ia - maneja error
    if (result.affectedRows === 0)
      return res.status(404).json({ error: 'Usuario no encontrado' }); // codigo de ia - no encontrado
    res.json({ message: 'Usuario eliminado' }); // codigo de ia - éxito
  });
});

