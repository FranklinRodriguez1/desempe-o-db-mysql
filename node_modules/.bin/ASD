// ============================================
// RUTA PARA SUBIR ARCHIVOS CSV
// ============================================
app.post('/api/upload-csv', upload.single('archivo'), (req, res) => {
  // codigo de ia - ruta para subir CSV
  if (!req.file) {
    // codigo de ia - verifica que venga archivo
    return res.status(400).json({ error: 'No se subió ningún archivo' }); // codigo de ia - error
  }

  const resultados = []; // codigo de ia - array para guardar datos
  const filePath = req.file.path; // codigo de ia - ruta del archivo

  fs.createReadStream(filePath) // codigo de ia - lee el archivo
    .pipe(csv()) // codigo de ia - parsea como CSV
    .on('data', (data) => resultados.push(data)) // codigo de ia - guarda cada fila
    .on('end', () => {
      // codigo de ia - cuando termina
      // Inserta los datos del CSV en la tabla productos
      let insertados = 0; // codigo de ia - contador de insertados
      let errores = 0; // codigo de ia - contador de errores

      resultados.forEach((producto) => {
        // codigo de ia - procesa cada producto
        const query =
          'INSERT INTO productos (nombre, descripcion, cantidad, precio, categoria) VALUES (?, ?, ?, ?, ?)'; // codigo de ia - SQL insert
        connection.query(
          query,
          [
            // codigo de ia - ejecuta insert
            producto.nombre || producto.Nombre, // codigo de ia - nombre (soporta mayúsculas)
            producto.descripcion || producto.Descripcion || '', // codigo de ia - descripción
            parseInt(producto.cantidad || producto.Cantidad) || 0, // codigo de ia - cantidad
            parseFloat(producto.precio || producto.Precio) || 0, // codigo de ia - precio
            producto.categoria || producto.Categoria || 'General', // codigo de ia - categoría
          ],
          (err) => {
            // codigo de ia - maneja error
            if (err) {
              // codigo de ia - si hay error
              console.error('Error insertando producto:', err); // codigo de ia - muestra error
              errores++; // codigo de ia - aumenta errores
            } else {
              // codigo de ia - si éxito
              insertados++; // codigo de ia - aumenta insertados
            }
          }
        );
      });

      // Limpia el archivo subido
      fs.unlinkSync(filePath); // codigo de ia - elimina archivo temporal

      res.json({
        // codigo de ia - respuesta final
        message: 'CSV procesado', // codigo de ia - mensaje
        total: resultados.length, // codigo de ia - total de filas
        insertados: insertados, // codigo de ia - insertados exitosos
        errores: errores, // codigo de ia - errores
      });
    });
});

